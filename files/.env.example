# App
APP_SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
APP_NAME=SeatBookingAuth
DEBUG=true

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/seat_booking_auth

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# OIDC (fill per tenant — stored in DB, these are defaults for dev)
OIDC_CALLBACK_BASE_URL=http://localhost:8000

# SAML (optional — for legacy enterprise)
SAML_CALLBACK_BASE_URL=http://localhost:8000
